# Ornek uretim ortami (Render / VPS / Docker) — degerleri gercek sirlarla doldurun; bu dosyayi commit etmeyin.

NODE_ENV=production

# Kanonik site adresi (https)
APP_URL=https://www.ornek.com

# Tam HTTPS üretimde: tarayıcıya HSTS bildir (localhost / HTTP testte KULLANMAYIN)
# ENABLE_HSTS=1

# PostgreSQL — Neon örnek (panodan kopyalayın; genelde ?sslmode=require):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
#
# Neon: havuzlu (pooler) URL uygulama için; migration için bazen doğrudan (non-pooler) URL gerekir.
# Bu durumda DIRECT_DATABASE_URL ekleyin — yalnızca `prisma migrate deploy` / build bu adresi kullanır.
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
#
# Supabase / RDS / diğer: sağlayıcı dokümantasyonuna uyun. Üretimde 127.0.0.1 veya localhost kullanmayın.
DATABASE_URL=
# DIRECT_DATABASE_URL=

AUTH_SECRET=
OTP_PEPPER=

# Coklu instance / serverless
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upload/storage provider
STORAGE_PROVIDER=s3
# ALLOW_LOCAL_UPLOADS_IN_PRODUCTION=0
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_PUBLIC_BASE_URL=
# S3_FORCE_PATH_STYLE=0
# S3_KEY_PREFIX=uploads
#
# İlan görsel URL host allowlist (virgülle):
# ALLOWED_UPLOAD_HOSTS=cdn.ornek.com

# Iyzico (alternatif: Yonetici > Odeme saglayicilari — veritabani)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://api.iyzipay.com

# PayTR iFrame (alternatif: Yonetici paneli; bildirim URL: {APP_URL}/api/payments/paytr/notify)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
# PAYTR_TEST_MODE=0

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# SMTP / Twilio (OTP / bildirim)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# /admin sifre alani: SUPER_ADMIN kullanici sifresi (DB). Eski: ADMIN_PANEL_PASSWORD artik kullanilmaz.
# ADMIN_PANEL_PASSWORD=
ADMIN_EMAIL=
