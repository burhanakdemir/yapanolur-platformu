# Copy to .env — never commit .env
#
# --- Oturum (tek mekanizma; NextAuth kullanilmaz) ---
# Uygulama oturumu: httpOnly `session_token` cerezi; JWT imzasi `jose` ile AUTH_SECRET ile yapilir.
# NextAuth paketi veya NextAuth route'lari yoktur. Asagidaki NEXTAUTH_* satirlari kodda okunmaz (yalnizca APP_URL
# yoksa `src/lib/appUrl.ts` icinde NEXTAUTH_URL yedek olarak kullanilir); tercihen APP_URL tanimlayin.
#
# --- Zorunlu ---
# DATABASE_URL: yalnizca PostgreSQL (SQLite file:... desteklenmez). Prisma Migrate prisma.config.ts ile bu adresi kullanir.
# AUTH_SECRET: oturum JWT imzasi — ornek: openssl rand -base64 32
# OTP_PEPPER: OTP hash — ornek: openssl rand -base64 24
#
# --- Yerel PostgreSQL (Docker) ---
# 1) docker compose up -d
# 2) Asagidaki DATABASE_URL (veya kendi kullanici/sifreniz) — varsayilan asagida
#
# --- Hiz limiti (uretimde onerilir; coklu sunucu / serverless icin) ---
# Upstash Redis REST: https://console.upstash.com — tanimlanmazsa tek Node surecinde bellek ici sayaç kullanilir.
# Birden fazla instance veya serverless: UPSTASH_* tanimlayin; aksi halde oran sinirlama tutarsiz olabilir.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Üretimde isteğe bağlı: yalnızca gerçek HTTPS domainde ENABLE_HSTS=1 (docs/go-live-checklist.md)
#
# --- Uretim kontrol listesi ---
# - APP_URL: https ile kanonik domain (odeme geri donusleri, Open Graph)
# - AUTH_SECRET / OTP_PEPPER: gucu yuksek rastgele degerler (asla repoya commit etmeyin)
# - DATABASE_URL: Neon / RDS / managed Postgres (SSL genelde ?sslmode=require). Barındırma: docs/hosting.md
# - DIRECT_DATABASE_URL: isteğe bağlı; yalnızca migrate için (Neon direct URL). Uygulama hâlâ DATABASE_URL kullanır.
# - UPSTASH_*: coklu replika veya serverless icin oran sinirlama
# - IYZICO_*: canli anahtarlar ve IYZICO_BASE_URL=https://api.iyzipay.com (sandbox degil)
# - BLOB_READ_WRITE_TOKEN: Vercel Blob (kalici upload)
# - SENTRY_*: istege bagli hata izleme
# Detay: docs/veritabani-ortamlar.md, .env.production.example
#
# --- Sentry (istege bagli) ---
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
#
# /admin "Süper yönetici şifresi" alanı, veritabanında SUPER_ADMIN rolü olan kullanıcının
# şifresini kullanır (login ile aynı). Asagidaki ortam sifreleri uygulama tarafindan KULLANILMAZ; eski dokuman izi.

DATABASE_URL="postgresql://ilan:ilan@127.0.0.1:5432/ilan_dev"
# Yerel: localhost yerine 127.0.0.1 onerilir (Windows IPv6). Otomatik duzeltme: src/lib/resolveDatabaseUrl.ts
# DATABASE_PREFER_IPV4=0  ile kapatilir (or. ozel host adlari).
# Baglanti gecikmesi (ms, varsayilan 15000): DATABASE_CONNECT_TIMEOUT_MS=20000
# Yerel Docker: URL'de ?sslmode=require kullanmayin (baglanti duser). Neon/RDS: genelde ?sslmode=require.
# Yukaridaki URL'yi ssl ile degistirdiyseniz ve yine yerel Docker kullaniyorsaniz:
# DATABASE_SSL_DISABLE=1

# Vercel Blob (üretimde kalıcı upload)
# BLOB_READ_WRITE_TOKEN=

AUTH_SECRET=

OTP_PEPPER=
# Kayit e-posta OTP kodu uygulama icinde 1 dakika gecerlidir (OTP_SIGNUP_EMAIL_TTL_MINUTES, src/lib/otp.ts).
# Diger OTP amaclari varsayilan 15 dk kalir.

# LAN / gelistirme — APP_URL konsoldaki adresle ayni protokol olsun
APP_URL=http://localhost:3000
NEXT_PUBLIC_HELP_CENTER_EMAIL=

# ADMIN_PANEL_PASSWORD=
# ADMIN_PANEL_PASSWORD_DEV=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# SMTP_SECURE=true  # 465 icin; 587 cogu kurulumda false
# Panelde SMTP host+kullanici panelde, sifre yalnizca burada: SMTP_PASS yeterli (SMTP_HOST bos olabilir).
# SMTP_REQUIRE_TLS=1 veya true — bazi kurumsal sunucularda STARTTLS zorunluysa acin (varsayilan kapali).
# SMTP_EXPLICIT_ENVELOPE=0 — MAIL FROM zarfini kapat; bazi MTA'lar reddediyorsa dene.
# SMTP_TLS_REJECT_UNAUTHORIZED=false — yalnizca test; self-signed TLS (uretimde onerilmez)

# Canlı destek: çevrimdışı iken ADMIN/SUPER_ADMIN listesine ek olarak bildirim (isteğe bağlı)
# SUPPORT_NOTIFY_EXTRA_EMAIL=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Genel İleti Merkezi JSON SMS (sendIletiMerkeziJsonSms) — süper yönetici paneli doluysa env gerekmez.
# ILETI_MERKEZI_USER = API anahtarı (panel: "kullanıcı")
# ILETI_MERKEZI_PASS = gizli anahtar (panel: "şifre", HMAC için)
# ILETI_MERKEZI_SENDER = onaylı gönderici başlığı
# Not: Ortam değişken adlarında ASCII kullanılır (ILETI_...); Türkçe İ harfi kullanmayın.
# ILETI_MERKEZI_USER=
# ILETI_MERKEZI_PASS=
# ILETI_MERKEZI_SENDER=

# Sandbox: https://sandbox-api.iyzipay.com — Canli: https://api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

ADMIN_EMAIL=
ADMIN_PASSWORD=

# Ödeme simülasyonu (/payments/simulate): üretimde kapalı; staging için ALLOW_PAYMENT_SIMULATE=1
# ALLOW_PAYMENT_SIMULATE=1
#
# Üye kayıt e-posta OTP: OTP_PEPPER zorunlu. E-posta gönderimi önce AdminSettings SMTP (Site ayarları),
# yoksa SMTP_HOST/SMTP_USER/SMTP_PASS (sendPasswordResetEmail ile aynı çözümleme).

# E-fatura / e-arşiv (Sovos — öncelik süper yönetici Ödeme paneli; bunlar yedek)
# EINVOICE_MODE=mock
# EINVOICE_MODE=sovos
# SOVOS_API_BASE_URL=
# SOVOS_API_KEY=
# SOVOS_API_SECRET=
