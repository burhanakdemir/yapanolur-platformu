{
  "name": "Ilan Platformu - Design Tokens",
  "global": {
    "colors": {
      "primary": "#000000",
      "background": "#F9FAFB",
      "surface": "#FFFFFF",
      "muted": "#6B7280",
      "text": "#111827",
      "accent": "#111827"
    },
    "spacing": {
      "xs": "4",
      "sm": "8",
      "md": "16",
      "lg": "24",
      "xl": "32"
    },
    "radius": {
      "sm": "6",
      "md": "8",
      "lg": "12"
    },
    "shadow": {
      "sm": "0 1px 2px rgba(0,0,0,0.05)",
      "md": "0 4px 12px rgba(0,0,0,0.08)"
    }
  },
  "typography": {
    "fontFamily": "Inter, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial",
    "h1": { "size": 32, "weight": 700, "lineHeight": 40 },
    "h2": { "size": 20, "weight": 600, "lineHeight": 28 },
    "body": { "size": 16, "weight": 400, "lineHeight": 24 },
    "small": { "size": 13, "weight": 400, "lineHeight": 20 }
  },
  "components": {
    "button": {
      "primary": { "bg": "primary", "color": "surface", "radius": "md", "padding": "md" },
      "outline": { "bg": "surface", "border": "1px solid #E5E7EB", "color": "text", "radius": "md", "padding": "md" }
    },
    "card": { "bg": "surface", "radius": "md", "shadow": "md", "padding": "md" },
    "formField": { "bg": "surface", "border": "1px solid #E5E7EB", "radius": "sm", "padding": "sm" }
  }
}
